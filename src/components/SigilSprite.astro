---
// A hidden SVG sprite of all 12 school sigils as <symbol id="sigil-{id}">.
// Lets the client island render any sigil with <use href="#sigil-evocation"/>
// instead of carrying SVG strings in JS. Reuses the same paths as Sigil.astro.
import type { SchoolId } from "../data/types";

const SIGILS: Record<SchoolId, string> = {
  enchantment: `<polygon points="32,6 54,18 54,46 32,58 10,46 10,18"/><polygon points="32,16 46,24 46,40 32,48 18,40 18,24" opacity="0.55"/><circle cx="32" cy="32" r="4" fill="#8e7338"/><line x1="32" y1="6" x2="32" y2="16"/><line x1="54" y1="18" x2="46" y2="24"/><line x1="54" y1="46" x2="46" y2="40"/><line x1="32" y1="58" x2="32" y2="48"/><line x1="10" y1="46" x2="18" y2="40"/><line x1="10" y1="18" x2="18" y2="24"/>`,
  transmutation: `<rect x="6" y="6" width="52" height="52"/><circle cx="32" cy="32" r="22"/><polygon points="32,14 50,46 14,46"/><circle cx="32" cy="36" r="3" fill="#8e7338"/>`,
  animation: `<rect x="6" y="6" width="52" height="52"/><path d="M32,18 A14,14 0 1,1 18,32 A10,10 0 1,1 32,22 A6,6 0 1,1 26,28"/><circle cx="32" cy="18" r="2" fill="#8e7338"/>`,
  evocation: `<circle cx="32" cy="32" r="8"/><line x1="32" y1="6" x2="32" y2="22"/><line x1="32" y1="42" x2="32" y2="58"/><line x1="6" y1="32" x2="22" y2="32"/><line x1="42" y1="32" x2="58" y2="32"/><line x1="14" y1="14" x2="24" y2="24"/><line x1="40" y1="40" x2="50" y2="50"/><line x1="14" y1="50" x2="24" y2="40"/><line x1="40" y1="24" x2="50" y2="14"/><circle cx="32" cy="32" r="2" fill="#8e7338"/>`,
  abjuration: `<path d="M32,6 L52,14 L52,34 Q52,50 32,58 Q12,50 12,34 L12,14 Z"/><path d="M32,14 L46,20 L46,34 Q46,46 32,52 Q18,46 18,34 L18,20 Z" opacity="0.55"/><line x1="32" y1="22" x2="32" y2="44"/><line x1="22" y1="32" x2="42" y2="32"/>`,
  kinesis: `<circle cx="32" cy="32" r="22"/><line x1="14" y1="32" x2="50" y2="32"/><polyline points="44,26 50,32 44,38"/><polyline points="20,26 14,32 20,38"/><circle cx="32" cy="32" r="2.5" fill="#8e7338"/>`,
  conjuration: `<path d="M16,16 C28,16 28,48 40,48 C52,48 52,16 40,16 C28,16 28,48 16,48"/><circle cx="16" cy="16" r="2" fill="#8e7338"/><circle cx="40" cy="16" r="2" fill="#8e7338"/><circle cx="16" cy="48" r="2" fill="#8e7338"/><circle cx="40" cy="48" r="2" fill="#8e7338"/>`,
  summoning: `<circle cx="32" cy="32" r="18"/><polygon points="32,16 38,30 50,30 40,38 44,50 32,42 20,50 24,38 14,30 26,30"/><line x1="32" y1="4" x2="32" y2="12"/><line x1="32" y1="52" x2="32" y2="60"/><line x1="4" y1="32" x2="12" y2="32"/><line x1="52" y1="32" x2="60" y2="32"/>`,
  pacting: `<circle cx="22" cy="32" r="14"/><circle cx="42" cy="32" r="14"/><line x1="6" y1="32" x2="58" y2="32" stroke-width="0.6"/><circle cx="22" cy="32" r="2" fill="#8e7338"/><circle cx="42" cy="32" r="2" fill="#8e7338"/>`,
  telepathy: `<path d="M14,32 A18,18 0 0,1 50,32"/><path d="M14,32 A18,18 0 0,0 50,32"/><circle cx="32" cy="32" r="4" fill="#8e7338"/><line x1="32" y1="14" x2="32" y2="20" opacity="0.5"/><line x1="32" y1="44" x2="32" y2="50" opacity="0.5"/>`,
  illusion: `<path d="M20,12 A20,20 0 1,0 20,52 A14,20 0 1,1 20,12 Z"/><path d="M44,12 A20,20 0 1,1 44,52 A14,20 0 1,0 44,12 Z" opacity="0.55"/><circle cx="32" cy="32" r="2" fill="#8e7338"/>`,
  delirium: `<path d="M32,8 C50,8 50,32 32,32 C14,32 14,56 32,56" stroke-dasharray="2 3"/><path d="M32,8 C18,8 18,32 32,32 C46,32 46,56 32,56" stroke-dasharray="2 3" opacity="0.6"/><circle cx="32" cy="32" r="3" fill="#8e7338"/><circle cx="32" cy="8" r="1.5" fill="#8e7338"/><circle cx="32" cy="56" r="1.5" fill="#8e7338"/>`,
};
const entries = Object.entries(SIGILS) as [SchoolId, string][];
---

<svg width="0" height="0" style="position: absolute" aria-hidden="true">
  <defs>
    {
      entries.map(([id, inner]) => (
        <symbol id={`sigil-${id}`} viewBox="0 0 64 64" fill="none" stroke="#8e7338" stroke-width="1.2" set:html={inner} />
      ))
    }
  </defs>
</svg>
